generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  password      String
  role          Role     @default(MEMBER)
  isActive      Boolean  @default(false)
  paymentStatus String   @default("pending")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Email confirmation. Default true so existing users and admin-created
  // accounts aren't locked out; self-registration sets it false explicitly.
  emailVerified Boolean @default(true)
  verifyToken   String? @unique

  // Membership window. membershipMonths = null means unlimited / no expiry.
  membershipStart  DateTime?
  membershipMonths Int?

  categoryAccess   UserCategoryAccess[]
  hiddenCategories UserHiddenCategory[]
  groupAccess      UserGroupAccess[]
  downloadLogs     DownloadLog[]
  subscriptions    SubscriptionRequest[]
}

model SmbServer {
  id       String @id @default(cuid())
  name     String
  host     String
  port     Int    @default(445)
  username String
  password String
  domain   String @default("")

  categoryPaths CategorySmbPath[]
}

model FtpServer {
  id       String  @id @default(cuid())
  name     String
  host     String
  port     Int     @default(21)
  username String
  password String
  secure   Boolean @default(false)
  passive  Boolean @default(true)

  categoryPaths CategoryFtpPath[]
}

model ScpServer {
  id         String @id @default(cuid())
  name       String
  host       String
  port       Int    @default(22)
  username   String
  password   String @default("")
  privateKey String @default("")
  passphrase String @default("")

  categoryPaths CategoryScpPath[]
}

model CategoryGroup {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  categories Category[]
  plans      MembershipPlan[]
  userAccess UserGroupAccess[]
}

// Group-level access/visibility override for a user. When a row exists for
// (user, group), it overrides per-category access/hidden for every category
// in that group. granted = access to all; hidden = hide all.
model UserGroupAccess {
  id      String  @id @default(cuid())
  userId  String
  groupId String
  granted Boolean @default(true)
  hidden  Boolean @default(false)
  // Independent per-package expiry. null = no expiry (unlimited / admin grant).
  expiresAt DateTime?
  grantedAt DateTime @default(now())
  grantedBy String?

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group CategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Category {
  id                   String  @id @default(cuid())
  name                 String
  description          String  @default("")
  affiliateLinkOverride String?
  sortOrder            Int     @default(0)
  imageUrl             String?
  groupId              String?

  group        CategoryGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  smbPaths     CategorySmbPath[]
  ftpPaths     CategoryFtpPath[]
  scpPaths     CategoryScpPath[]
  userAccess   UserCategoryAccess[]
  hiddenForUsers UserHiddenCategory[]
  hideRules    HideRule[]
  downloadLogs DownloadLog[]
}

// Rules that hide files/folders from the file browser. categoryId null means
// the rule is global (applies to every category). pattern supports * and ?
// wildcards. target restricts to 'file', 'folder', or 'both'.
model HideRule {
  id         String   @id @default(cuid())
  categoryId String?
  pattern    String
  target     String   @default("both")
  createdAt  DateTime @default(now())

  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model CategorySmbPath {
  id          String @id @default(cuid())
  categoryId  String
  smbServerId String
  path        String

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  smbServer SmbServer @relation(fields: [smbServerId], references: [id], onDelete: Cascade)
}

model CategoryFtpPath {
  id          String @id @default(cuid())
  categoryId  String
  ftpServerId String
  path        String

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  ftpServer FtpServer @relation(fields: [ftpServerId], references: [id], onDelete: Cascade)
}

model CategoryScpPath {
  id          String @id @default(cuid())
  categoryId  String
  scpServerId String
  path        String

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  scpServer ScpServer @relation(fields: [scpServerId], references: [id], onDelete: Cascade)
}

model UserCategoryAccess {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  grantedAt  DateTime @default(now())
  grantedBy  String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
}

model AffiliateSettings {
  id         String   @id @default(cuid())
  globalLink String   @default("")
  updatedAt  DateTime @updatedAt
}

// Per-user hidden categories. A row here means the category is hidden from
// that member entirely (not just locked). Absence = visible (subject to the
// normal access / locked rules).
model UserHiddenCategory {
  id         String @id @default(cuid())
  userId     String
  categoryId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
}

// Singleton row holding site branding + SMTP config. There should only ever
// be one row; the app reads findFirst() and creates it on demand.
model SiteSettings {
  id             String  @id @default(cuid())
  siteTitle      String  @default("SecureFiles")
  heroHeading    String  @default("Download anything, from anywhere")
  heroSubheading String  @default("Secure, members-only file downloads.")

  // SMTP / email
  smtpEnabled   Boolean @default(false)
  smtpHost      String  @default("")
  smtpPort      Int     @default(587)
  smtpSecure    Boolean @default(false)
  smtpUser      String  @default("")
  smtpPassword  String  @default("")
  smtpFromEmail String  @default("")
  smtpFromName  String  @default("")

  // Contact + payment
  contactEmail  String  @default("")
  bankAccount   String  @default("")
  paymentQrUrl  String?

  // Membership card footer note
  cardFooterNote String @default("เก็บบัตรนี้ไว้เป็นความลับ")

  // Tooltip shown on disabled Download/Play buttons for non-members
  memberOnlyNotice String @default("สำหรับสมาชิกเท่านั้น ศึกษารายละเอียดได้ที่หน้า Subscription")

  // Message shown at login when the account email isn't confirmed yet
  loginUnverifiedNotice String @default("กรุณายืนยันการสมัครผ่านลิงก์ที่ส่งไปยังอีเมลของคุณ")

  // Logo & tagline
  logoUrl             String  @default("")
  logoSize            Int     @default(36)   // px — shown in NavBar
  siteTagline         String  @default("")

  // File browser pagination (items per page)
  fileBrowserPageSize Int     @default(20)

  // Guest (unauthenticated) access — play-only, no download
  guestEnabled    Boolean @default(false)
  guestDailyLimit Int     @default(5)

  updatedAt DateTime @updatedAt
}

// Daily play quota tracker for unauthenticated (guest) users, keyed by IP.
// One row per (ip, date); count is incremented each time /api/stream is called.
model GuestPlayLog {
  id        String   @id @default(cuid())
  ip        String
  date      String   // YYYY-MM-DD UTC
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([ip, date])
}

// Subscription plans an admin offers. priceThb is whole Thai Baht.
model MembershipPlan {
  id        String  @id @default(cuid())
  name      String
  months    Int
  priceThb  Int
  active    Boolean @default(true)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  groupId   String?

  group    CategoryGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  requests SubscriptionRequest[]
}

// A member's request to buy/extend a subscription.
// status: wait_payment -> wait_confirm -> paid | failed
model SubscriptionRequest {
  id             String   @id @default(cuid())
  userId         String
  planId         String?
  planName       String
  months         Int
  priceThb       Int
  status         String   @default("wait_payment")
  slipUrl        String?
  groupId        String?
  previousExpiry DateTime?
  newExpiry      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  paidAt         DateTime?

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan MembershipPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
}

// Advertising banners shown at the bottom of pages. Clicking opens linkUrl
// in a new tab (if set).
model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  linkUrl   String   @default("")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Access event log — tracks logins, guest browses, and plays.
// categoryName / username are denormalized so history is preserved
// even after a user or category is deleted.
model AccessLog {
  id           String   @id @default(cuid())
  type         String   // LOGIN | GUEST_BROWSE | GUEST_PLAY | MEMBER_PLAY
  ip           String   @default("")
  userId       String?
  userEmail    String?
  username     String?
  categoryId   String?
  categoryName String?
  filePath     String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@index([ip])
  @@index([userId])
}

model DownloadLog {
  id           String   @id @default(cuid())
  userId       String
  categoryId   String
  filePath     String
  affiliateUrl String?
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}
