generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  password      String
  role          Role     @default(MEMBER)
  isActive      Boolean  @default(false)
  paymentStatus String   @default("pending")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Email confirmation. Default true so existing users and admin-created
  // accounts aren't locked out; self-registration sets it false explicitly.
  emailVerified Boolean @default(true)
  verifyToken   String? @unique

  // Membership window. membershipMonths = null means unlimited / no expiry.
  membershipStart  DateTime?
  membershipMonths Int?

  categoryAccess   UserCategoryAccess[]
  hiddenCategories UserHiddenCategory[]
  downloadLogs     DownloadLog[]
  subscriptions    SubscriptionRequest[]
}

model SmbServer {
  id       String @id @default(cuid())
  name     String
  host     String
  port     Int    @default(445)
  username String
  password String
  domain   String @default("")

  categoryPaths CategorySmbPath[]
}

model FtpServer {
  id       String  @id @default(cuid())
  name     String
  host     String
  port     Int     @default(21)
  username String
  password String
  secure   Boolean @default(false)
  passive  Boolean @default(true)

  categoryPaths CategoryFtpPath[]
}

model ScpServer {
  id         String @id @default(cuid())
  name       String
  host       String
  port       Int    @default(22)
  username   String
  password   String @default("")
  privateKey String @default("")
  passphrase String @default("")

  categoryPaths CategoryScpPath[]
}

model Category {
  id                   String  @id @default(cuid())
  name                 String
  description          String  @default("")
  affiliateLinkOverride String?
  sortOrder            Int     @default(0)
  imageUrl             String?

  smbPaths     CategorySmbPath[]
  ftpPaths     CategoryFtpPath[]
  scpPaths     CategoryScpPath[]
  userAccess   UserCategoryAccess[]
  hiddenForUsers UserHiddenCategory[]
  downloadLogs DownloadLog[]
}

model CategorySmbPath {
  id          String @id @default(cuid())
  categoryId  String
  smbServerId String
  path        String

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  smbServer SmbServer @relation(fields: [smbServerId], references: [id], onDelete: Cascade)
}

model CategoryFtpPath {
  id          String @id @default(cuid())
  categoryId  String
  ftpServerId String
  path        String

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  ftpServer FtpServer @relation(fields: [ftpServerId], references: [id], onDelete: Cascade)
}

model CategoryScpPath {
  id          String @id @default(cuid())
  categoryId  String
  scpServerId String
  path        String

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  scpServer ScpServer @relation(fields: [scpServerId], references: [id], onDelete: Cascade)
}

model UserCategoryAccess {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  grantedAt  DateTime @default(now())
  grantedBy  String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
}

model AffiliateSettings {
  id         String   @id @default(cuid())
  globalLink String   @default("")
  updatedAt  DateTime @updatedAt
}

// Per-user hidden categories. A row here means the category is hidden from
// that member entirely (not just locked). Absence = visible (subject to the
// normal access / locked rules).
model UserHiddenCategory {
  id         String @id @default(cuid())
  userId     String
  categoryId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
}

// Singleton row holding site branding + SMTP config. There should only ever
// be one row; the app reads findFirst() and creates it on demand.
model SiteSettings {
  id             String  @id @default(cuid())
  siteTitle      String  @default("SecureFiles")
  heroHeading    String  @default("Download anything, from anywhere")
  heroSubheading String  @default("Secure, members-only file downloads.")

  // SMTP / email
  smtpEnabled   Boolean @default(false)
  smtpHost      String  @default("")
  smtpPort      Int     @default(587)
  smtpSecure    Boolean @default(false)
  smtpUser      String  @default("")
  smtpPassword  String  @default("")
  smtpFromEmail String  @default("")
  smtpFromName  String  @default("")

  // Contact + payment
  contactEmail  String  @default("")
  bankAccount   String  @default("")
  paymentQrUrl  String?

  // Membership card footer note
  cardFooterNote String @default("เก็บบัตรนี้ไว้เป็นความลับ")

  // Tooltip shown on disabled Download/Play buttons for non-members
  memberOnlyNotice String @default("สำหรับสมาชิกเท่านั้น ศึกษารายละเอียดได้ที่หน้า Subscription")

  updatedAt DateTime @updatedAt
}

// Subscription plans an admin offers. priceThb is whole Thai Baht.
model MembershipPlan {
  id        String  @id @default(cuid())
  name      String
  months    Int
  priceThb  Int
  active    Boolean @default(true)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())

  requests SubscriptionRequest[]
}

// A member's request to buy/extend a subscription.
// status: wait_payment -> wait_confirm -> paid | failed
model SubscriptionRequest {
  id             String   @id @default(cuid())
  userId         String
  planId         String?
  planName       String
  months         Int
  priceThb       Int
  status         String   @default("wait_payment")
  slipUrl        String?
  previousExpiry DateTime?
  newExpiry      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  paidAt         DateTime?

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan MembershipPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
}

model DownloadLog {
  id           String   @id @default(cuid())
  userId       String
  categoryId   String
  filePath     String
  affiliateUrl String?
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}
